# Production Environment Variables Template
# Replace values with your actual production credentials

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://prod-db.example.com:5432/ems_production
SPRING_DATASOURCE_USERNAME=ems_user
SPRING_DATASOURCE_PASSWORD=very_strong_password_here

# JWT Configuration - IMPORTANT: Use a strong random secret
# Generate with: openssl rand -base64 32
JWT_SECRET=use_a_256_bit_random_string_generated_securely
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# CORS Configuration
APP_CORS_ALLOWED_ORIGIN=https://yourdomain.com

# Logging
SPRING_JPA_SHOW_SQL=false
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_EMS=INFO

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# SSL/TLS Configuration
SERVER_SSL_ENABLED=true
SERVER_SSL_KEY_STORE=/path/to/keystore.jks
SERVER_SSL_KEY_STORE_PASSWORD=keystore_password
SERVER_SSL_KEY_STORE_TYPE=JKS

# Profiles
SPRING_PROFILES_ACTIVE=prod

# Actuator (for health checks)
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

# Database Connection Pooling
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000

# Backup Configuration
BACKUP_SCHEDULE=0 0 2 * * *
BACKUP_RETENTION_DAYS=30
