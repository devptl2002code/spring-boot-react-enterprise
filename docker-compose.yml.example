version: '3.8'

services:
  # PostgreSQL Database (for production-like environment)
  postgres:
    image: postgres:15-alpine
    container_name: ems_postgres
    environment:
      POSTGRES_DB: ems_database
      POSTGRES_USER: ems_user
      POSTGRES_PASSWORD: ems_password_dev
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - ems_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ems_user -d ems_database"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Redis Cache (optional - for caching layer)
  redis:
    image: redis:7-alpine
    container_name: ems_redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    networks:
      - ems_network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Spring Boot Backend
  backend:
    build:
      context: ./ems_backend
      dockerfile: Dockerfile
    container_name: ems_backend
    ports:
      - "8080:8080"
    environment:
      SPRING_DATASOURCE_URL: jdbc:postgresql://postgres:5432/ems_database
      SPRING_DATASOURCE_USERNAME: ems_user
      SPRING_DATASOURCE_PASSWORD: ems_password_dev
      SPRING_PROFILES_ACTIVE: prod
      JWT_SECRET: dev_secret_key_change_in_production
      APP_CORS_ALLOWED_ORIGIN: http://localhost:5173
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - ems_network
    volumes:
      - ./ems_backend/logs:/app/logs

  # React Frontend
  frontend:
    build:
      context: ./ems_frontend
      dockerfile: Dockerfile
    container_name: ems_frontend
    ports:
      - "80:80"
    environment:
      VITE_API_URL: http://localhost:8080/api
      VITE_APP_ENV: production
    depends_on:
      - backend
    networks:
      - ems_network

  # Nginx Reverse Proxy (optional - for production-like setup)
  nginx:
    image: nginx:alpine
    container_name: ems_nginx
    ports:
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/nginx/ssl:ro
    depends_on:
      - backend
      - frontend
    networks:
      - ems_network

volumes:
  postgres_data:
  redis_data:

networks:
  ems_network:
    driver: bridge
